{
  "name": "polychromatic-theme",
  "displayName": "Polychromatic Theme",
  "description": "Polychromatic Theme",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.51.0"
  },
  "main": "./extension.js",
  "activationEvents": [
    "*"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ottowolfenden/polychromatic-theme.git"
  },
  "contributes": {
    "themes": [
      {
        "label": "Polychromatic Theme Dark",
        "uiTheme": "vs-dark",
        "path": "./themes/dark.json"
      },
      {
        "label": "Polychromatic Theme Light",
        "uiTheme": "vs",
        "path": "./themes/light.json"
      }
    ]
  },
  "extensionDependencies": [
    "subframe7536.custom-ui-style"
  ]
}